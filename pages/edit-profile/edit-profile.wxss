/* pages/edit-profile/edit-profile.wxss */

page {
  background: #F4F4F0;
}

.edit-container {
  width: 100%;
  min-height: 100vh;
  background: #F4F4F0;
  display: flex;
  flex-direction: column;
}

/* ===== 顶部导航 ===== */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 96rpx 40rpx 24rpx;
  background: #F4F4F0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  transition: all 0.2s;
}

.nav-back:active {
  transform: scale(0.9);
}

.nav-back-icon {
  font-size: 36rpx;
  color: #1C1917;
  font-weight: 600;
  line-height: 1;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #1C1917;
  letter-spacing: -0.5rpx;
}

.nav-save-btn {
  background: #E76F51;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  padding: 16rpx 40rpx;
  border-radius: 999rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(231,111,81,0.3);
  line-height: 1.4;
  margin: 0;
  transition: all 0.2s;
}

.nav-save-btn::after {
  border: none;
}

.nav-save-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 10rpx rgba(231,111,81,0.2);
}

/* ===== 滚动区域 ===== */
.edit-scroll {
  flex: 1;
  height: calc(100vh - 200rpx);
}

.edit-body {
  padding: 16rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ===== 头像区域 ===== */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 32rpx;
}

.edit-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
  margin-bottom: 16rpx;
  background: #F5F5F4;
}

.avatar-hint {
  font-size: 24rpx;
  color: #E76F51;
  font-weight: 600;
}

/* ===== 字段区域 ===== */
.field-section {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx 40rpx;
  box-shadow: 0 4rpx 20rpx -10rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(231,229,228,0.5);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.field-label {
  font-size: 24rpx;
  font-weight: 800;
  color: #A8A29E;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.field-input {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1917;
  border: none;
  padding: 0;
  background: transparent;
  line-height: 1.5;
}

.field-placeholder {
  color: #D6D3D1;
  font-weight: 400;
}

.field-textarea {
  font-size: 28rpx;
  font-weight: 500;
  color: #1C1917;
  border: none;
  padding: 0;
  background: transparent;
  line-height: 1.7;
  min-height: 120rpx;
  width: 100%;
}

.field-count {
  font-size: 22rpx;
  color: #D6D3D1;
  text-align: right;
  font-weight: 500;
}

/* ===== 标签区域 ===== */
.tags-selected {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  align-items: center;
}

.tag-pill {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  transition: all 0.2s;
}

.tag-selected {
  background: #E76F51;
  color: #FFFFFF;
}

.tag-selected:active {
  transform: scale(0.95);
}

.tag-text {
  line-height: 1;
}

.tag-remove {
  font-size: 28rpx;
  line-height: 1;
  font-weight: 400;
  opacity: 0.8;
  margin-left: -4rpx;
}

.tag-add-input-wrap {
  flex: 1;
  min-width: 160rpx;
}

.tag-add-input {
  font-size: 24rpx;
  color: #A8A29E;
  border: 2rpx dashed #D6D3D1;
  border-radius: 999rpx;
  padding: 12rpx 24rpx;
  background: transparent;
  width: 100%;
  box-sizing: border-box;
}

.tag-add-placeholder {
  color: #D6D3D1;
}

/* ===== 推荐标签 ===== */
.recommended-section {
  margin-top: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recommended-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #A8A29E;
  letter-spacing: 1rpx;
}

.recommended-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-recommended {
  background: #F5F5F4;
  color: #78716C;
  border: 2rpx solid rgba(231,229,228,0.8);
}

.tag-recommended:active {
  transform: scale(0.95);
  background: #E7E5E4;
}

.tag-recommended-selected {
  background: rgba(231,111,81,0.1);
  color: #E76F51;
  border: 2rpx solid rgba(231,111,81,0.3);
}

/* ===== 底部 ===== */
.bottom-spacer {
  height: 80rpx;
}
