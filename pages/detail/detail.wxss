/* pages/detail/detail.wxss - 独立判定解析页面，复用 feed 样式 */
@import "../feed/feed.wxss";

/* ===== 容器 - 覆盖 feed 的 feed-container ===== */
.detail-container {
  width: 100vw;
  min-height: 100vh;
  background: var(--bg-primary, #F4F4F0);
  position: relative;
}

/* ===== 加载/错误状态 ===== */
.loading-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid var(--bg-secondary, #F0EEE6);
  border-top-color: var(--accent-clay, #D97757);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-main, #1D1C16);
  font-family: var(--font-body);
}

.error-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 60rpx;
}

.error-text {
  font-size: 28rpx;
  color: var(--text-main, #1D1C16);
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.8;
  font-family: var(--font-body);
}

.retry-btn {
  padding: 28rpx 72rpx;
  background: var(--accent-clay, #D97757);
  color: #FFFFFF;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  font-family: var(--font-body);
  line-height: 1.6;
}

.retry-btn::after {
  border: none;
}
