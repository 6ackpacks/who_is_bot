/* pages/profile/profile.wxss - Claude风格个人主页样式 */

/* ===== 颜色变量 ===== */
page {
  --bg-primary: #F9F8F6;
  --bg-card: #F0EEE6;
  --accent-clay: #D97757;
  --text-main: #1D1C16;
  --text-secondary: #66655F;
  --surface-white: #FFFFFF;
  --border-light: #E8E6DC;
  --paper-color: #F9F8F6;
  --error-red: #FF6B6B;
  --success-color: #10B981;
  --error-color: #EF4444;
}

/* ===== 容器 ===== */
.profile-container {
  width: 100%;
  min-height: 100vh;
  background: var(--bg-primary);
}

.profile-scroll {
  width: 100%;
  height: 100vh;
}

/* ===== 个人资料主区域 ===== */
.profile-wrapper {
  background: var(--surface-white);
  padding: 40rpx 40rpx 56rpx; 
  border-radius: 0 0 32rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
  margin-bottom: 24rpx;
}

/* ===== 顶部操作区 ===== */
.top-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.btn-logout,
.btn-edit {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.5;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
}

.btn-edit {
  background: var(--bg-card);
  color: var(--text-main);
  border: 1rpx solid var(--border-light);
}

.btn-logout {
  background: rgba(239, 68, 68, 0.08); 
  color: var(--error-red);
  border: 1rpx solid rgba(239, 68, 68, 0.2);
}

.btn-logout::after, .btn-edit::after { 
  border: none; 
}

.btn-edit:active, .btn-logout:active {
  transform: scale(0.96);
  opacity: 0.8;
}

/* ===== 用户核心信息 ===== */
.user-core-info {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 48rpx;
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid var(--surface-white);
  background: var(--bg-card);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
  object-fit: cover;
}

.user-text-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.profile-nickname {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-main);
  margin-bottom: 12rpx;
  line-height: 1.3;
}

.profile-bio {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* ===== 统计卡片 ===== */
.stats-cards {
  display: flex;
  gap: 20rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 16rpx;
  background: var(--bg-primary); 
  border: 1rpx solid var(--border-light);
  border-radius: 20rpx;
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 6rpx;
  background: var(--accent-clay);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.stat-card:hover::before {
  opacity: 1;
}

.stat-card:active {
  transform: scale(0.96);
  background: #EAE8DD;
}

.stat-card-number {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--accent-clay);
  margin-bottom: 8rpx;
  font-family: inherit;
  line-height: 1.2;
}

.stat-card-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

/* ===== 标签页 ===== */
.tabs-container {
  background: var(--bg-primary);
  margin-top: 16rpx;
}

.tabs-header {
  position: relative;
  display: flex;
  background: var(--surface-white);
  border-radius: 16rpx 16rpx 0 0;
  padding: 0 40rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
  transition: color 0.3s ease;
}

.tab-item.active .tab-text {
  color: var(--accent-clay);
  font-weight: 600;
}

/* 下划线指示器 - Claude风格发光效果 */
.tab-indicator {
  position: absolute;
  bottom: 0;
  height: 3rpx;
  background: var(--accent-clay);
  box-shadow: 0 0 12rpx rgba(217, 119, 87, 0.6);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border-radius: 2rpx 2rpx 0 0;
}

.tab-content {
  min-height: 400rpx;
  padding: 24rpx 40rpx;
  background: var(--surface-white);
  border-radius: 0 0 16rpx 16rpx;
}

/* ===== 判定记录列表 ===== */
.judgment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.judgment-item {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: var(--bg-card);
  border-radius: 12rpx;
  border: 1rpx solid var(--border-light);
  transition: all 0.2s ease;
}

.judgment-item:active {
  transform: scale(0.98);
  background: #EAE8DD;
}

.judgment-thumbnail {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: var(--bg-primary);
}

.judgment-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
}

.judgment-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-main);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.judgment-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.judgment-result {
  font-size: 24rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.judgment-result.correct {
  color: var(--success-color);
  background: rgba(16, 185, 129, 0.1);
}

.judgment-result.incorrect {
  color: var(--error-color);
  background: rgba(239, 68, 68, 0.1);
}

.judgment-time {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ===== 评论列表 ===== */
.comment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.comment-item {
  padding: 24rpx;
  background: var(--bg-card);
  border-radius: 12rpx;
  border: 1rpx solid var(--border-light);
  transition: all 0.2s ease;
}

.comment-item:active {
  transform: scale(0.98);
  background: #EAE8DD;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.comment-content-title {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.comment-time {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.comment-text {
  font-size: 28rpx;
  color: var(--text-main);
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.comment-footer {
  display: flex;
  justify-content: flex-end;
}

.comment-likes {
  font-size: 24rpx;
  color: var(--accent-clay);
  font-weight: 600;
}

/* ===== 申请提交表单 ===== */
.submit-form {
  background: var(--surface-white);
  padding: 0;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 16rpx;
}

.picker-view {
  padding: 24rpx;
  background: var(--bg-card);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-main);
  border: 1rpx solid var(--border-light);
}

.form-input {
  width: 100%;
  padding: 24rpx;
  background: var(--bg-card);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-main);
  border: 1rpx solid var(--border-light);
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background: var(--bg-card);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-main);
  border: 1rpx solid var(--border-light);
  box-sizing: border-box;
  line-height: 1.6;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.btn-submit {
  width: 100%;
  padding: 24rpx;
  background: var(--accent-clay);
  color: var(--surface-white);
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-top: 16rpx;
}

.btn-submit::after {
  border: none;
}

/* ===== 空状态 ===== */
.empty-state {
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* ===== 底部占位 ===== */
.bottom-spacer {
  height: 120rpx;
}

/* ===== 编辑资料弹窗 ===== */
.edit-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
}

.edit-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
}

.edit-modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  max-height: 80vh;
  background: var(--surface-white);
  border-radius: 32rpx 32rpx 0 0;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.edit-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.edit-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
}

.edit-modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--text-secondary);
  cursor: pointer;
}

.edit-modal-body {
  padding: 40rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.edit-section {
  margin-bottom: 32rpx;
}

.edit-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 16rpx;
}

.avatar-edit {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--bg-card);
}

.btn-change-avatar {
  padding: 16rpx 32rpx;
  background: var(--bg-card);
  color: var(--accent-clay);
  border: 1rpx solid var(--accent-clay);
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.btn-change-avatar::after {
  border: none;
}

.edit-input {
  width: 100%;
  padding: 24rpx;
  background: var(--bg-card);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-main);
  border: 1rpx solid var(--border-light);
  box-sizing: border-box;
}

.edit-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx;
  background: var(--bg-card);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-main);
  border: 1rpx solid var(--border-light);
  box-sizing: border-box;
  line-height: 1.6;
}

.edit-modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 40rpx;
  border-top: 1rpx solid var(--border-light);
}

.btn-cancel,
.btn-save {
  flex: 1;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-cancel {
  background: var(--bg-card);
  color: var(--text-secondary);
  border: 1rpx solid var(--border-light);
}

.btn-cancel::after {
  border: none;
}

.btn-save {
  background: var(--accent-clay);
  color: var(--surface-white);
  border: none;
}

.btn-save::after {
  border: none;
}
