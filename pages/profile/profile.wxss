/* pages/profile/profile.wxss */

/* ===== 颜色变量 ===== */
page {
  --bg-primary: #F4F4F0;
  --bg-card: #FAFAFA;
  --accent-clay: #E76F51;
  --accent-clay-muted: #D97757;
  --text-main: #1C1917;
  --text-secondary: #78716C;
  --text-muted: #A8A29E;
  --surface-white: #FFFFFF;
  --border-light: rgba(231, 229, 228, 0.6);
  --success-color: #10B981;
  --error-color: #E76F51;
}

/* ===== 容器 ===== */
.profile-container {
  width: 100%;
  min-height: 100vh;
  background: var(--bg-primary);
}

.profile-scroll {
  width: 100%;
  height: 100vh;
}

/* ===== 顶部导航栏 ===== */
.profile-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 56rpx 48rpx 24rpx;
  background: var(--bg-primary);
}

.profile-nav-title {
  font-size: 52rpx;
  font-weight: 900;
  color: var(--text-main);
  letter-spacing: -1rpx;
}

.profile-nav-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nav-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-btn-edit {
  padding: 14rpx 28rpx;
  background: var(--surface-white);
  border-radius: 999rpx;
  border: 2rpx solid #E7E5E4;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.nav-btn-edit:active {
  background: #F5F5F4;
}

.nav-btn-logout {
  width: 64rpx;
  height: 64rpx;
  background: #FEF2F2;
  border-radius: 50%;
  border: 2rpx solid rgba(239, 68, 68, 0.12);
}

.nav-btn-logout:active {
  background: #FEE2E2;
}

.nav-btn-login {
  padding: 14rpx 28rpx;
  background: var(--accent-clay);
  border-radius: 999rpx;
}

.nav-btn-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.nav-btn-login .nav-btn-text {
  color: #FFFFFF;
}

.nav-btn-logout-icon {
  font-size: 28rpx;
  color: #EF4444;
}

/* ===== 个人资料卡片 ===== */
.profile-wrapper {
  background: var(--surface-white);
  padding: 48rpx 48rpx 56rpx;
  border-radius: 0 0 64rpx 64rpx;
  box-shadow: 0 20rpx 40rpx -15rpx rgba(0, 0, 0, 0.05);
  border-bottom: 2rpx solid rgba(231, 229, 228, 0.5);
}

/* ===== 用户核心信息 ===== */
.user-core-info {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 56rpx;
}

.avatar-wrapper {
  position: relative;
  flex-shrink: 0;
  margin-bottom: 32rpx;
}

.user-avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 8rpx solid var(--surface-white);
  background: #F5F5F4;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  display: block;
}

.avatar-status-dot {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  width: 30rpx;
  height: 30rpx;
  background: #10B981;
  border: 4rpx solid var(--surface-white);
  border-radius: 50%;
}

.profile-nickname {
  font-size: 64rpx;
  font-weight: 900;
  color: var(--text-main);
  margin-bottom: 24rpx;
  line-height: 1.2;
  letter-spacing: -2rpx;
}

/* 留白区域（替代"设置状态"框） - 无简介时显示 */
.status-spacer {
  width: 100%;
  padding: 20rpx 0;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-spacer-text {
  font-size: 26rpx;
  color: #C4BFBB;
  font-style: italic;
  text-align: center;
  line-height: 1.5;
}

.profile-bio {
  font-size: 28rpx;
  color: #57534E;
  line-height: 1.85;
  margin-bottom: 40rpx;
  width: 100%;
  display: block;
  white-space: pre-wrap;
  word-break: break-all;
  letter-spacing: 0.3rpx;
}

/* ===== 统计卡片 ===== */
.stats-cards {
  display: flex;
  gap: 24rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 16rpx;
  background: #FAFAFA;
  border: 2rpx solid rgba(231, 229, 228, 0.6);
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.stat-card:active {
  background: #F5F5F4;
}

.stat-card-number {
  font-size: 40rpx;
  font-weight: 900;
  color: #1C1917;
  margin-bottom: 8rpx;
  line-height: 1.2;
  letter-spacing: -1rpx;
}

.stat-number-accent {
  color: #E76F51;
}

.stat-number-dark {
  color: #1C1917;
}

.stat-card-label {
  font-size: 20rpx;
  color: var(--text-muted);
  font-weight: 700;
}

/* ===== 标签页 ===== */
.tabs-container {
  background: transparent;
  margin-top: 0;
}

.tabs-header {
  position: sticky;
  top: 0;
  z-index: 20;
  background: rgba(244, 244, 240, 0.9);
  -webkit-backdrop-filter: blur(20rpx);
  backdrop-filter: blur(20rpx);
  display: flex;
  padding: 16rpx 48rpx 8rpx;
  gap: 0;
  justify-content: space-between;
  align-items: center;
}

.sticky-tabs {
  position: sticky;
  top: 0;
  z-index: 20;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx 24rpx;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #A8A29E;
}

.tab-item.active .tab-text {
  color: #1C1917;
  font-weight: 800;
}

.tab-indicator {
  position: absolute;
  bottom: 8rpx;
  height: 8rpx;
  background: #E76F51;
  border-radius: 4rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-content {
  min-height: 400rpx;
  padding: 16rpx 32rpx 32rpx;
  background: transparent;
}

/* ===== 判定记录列表 ===== */
.judgment-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.judgment-item {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 24rpx;
  background: var(--surface-white);
  border-radius: 32rpx;
  border: 2rpx solid rgba(245, 245, 244, 1);
  box-shadow: 0 4rpx 20rpx -10rpx rgba(0, 0, 0, 0.06);
}

.judgment-item:active {
  background: #FAFAFA;
}

/* 缩略图基础样式 */
.judgment-thumbnail {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #F5F5F4;
  overflow: hidden;
}

/* 文字类型缩略图 */
.thumb-text {
  background: linear-gradient(145deg, #1C1917 0%, #292524 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx;
  box-sizing: border-box;
}

.thumb-text-content {
  font-size: 17rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-align: center;
  letter-spacing: 0.5rpx;
}

/* 视频类型缩略图 */
.thumb-video {
  position: relative;
  background: #1C1917;
}

.thumb-video-img {
  width: 112rpx;
  height: 112rpx;
  display: block;
}

.thumb-video-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
}

.thumb-video-play {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.judgment-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16rpx;
  min-width: 0;
}

.judgment-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1C1917;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.judgment-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.judgment-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.badge-correct {
  background: rgba(16, 185, 129, 0.08);
  color: #059669;
}

.badge-incorrect {
  background: rgba(231, 111, 81, 0.1);
  color: #E76F51;
}

.badge-icon {
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1;
}

.badge-text {
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
}

.judgment-time {
  font-size: 20rpx;
  color: var(--text-muted);
  font-weight: 500;
}

.judgment-chevron {
  font-size: 40rpx;
  color: #D6D3D1;
  font-weight: 300;
  flex-shrink: 0;
  line-height: 1;
}

/* ===== 评论列表 ===== */
.comment-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.comment-item {
  padding: 32rpx;
  background: var(--surface-white);
  border-radius: 32rpx;
  border: 2rpx solid rgba(245, 245, 244, 1);
  box-shadow: 0 4rpx 20rpx -10rpx rgba(0, 0, 0, 0.06);
}

.comment-item:active {
  background: #FAFAFA;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.comment-content-title {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.comment-time {
  font-size: 20rpx;
  color: var(--text-muted);
}

.comment-text {
  font-size: 28rpx;
  color: var(--text-main);
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.comment-footer {
  display: flex;
  justify-content: flex-end;
}

.comment-likes {
  font-size: 24rpx;
  color: #E76F51;
  font-weight: 700;
}

/* ===== 申请提交表单 ===== */
.submit-form {
  background: transparent;
  padding: 16rpx 0;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 16rpx;
}

.picker-view {
  padding: 24rpx 32rpx;
  background: var(--surface-white);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--text-main);
  border: 2rpx solid rgba(231, 229, 228, 0.6);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.form-input {
  width: 100%;
  padding: 24rpx 32rpx;
  background: var(--surface-white);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--text-main);
  border: 2rpx solid rgba(231, 229, 228, 0.6);
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx 32rpx;
  background: var(--surface-white);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--text-main);
  border: 2rpx solid rgba(231, 229, 228, 0.6);
  box-sizing: border-box;
  line-height: 1.6;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.btn-submit {
  width: 100%;
  padding: 32rpx;
  background: #E76F51;
  color: var(--surface-white);
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  margin-top: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(231, 111, 81, 0.3);
}

.btn-submit::after {
  border: none;
}

.btn-submit:active {
  background: #D97757;
}

/* ===== 空状态 ===== */
.empty-state {
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
  font-weight: 500;
}

/* ===== 底部占位 ===== */
.bottom-spacer {
  height: 160rpx;
}

/* ===== 编辑资料弹窗 ===== */
.edit-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
}

.edit-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
}

.edit-modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  max-height: 80vh;
  background: var(--surface-white);
  border-radius: 48rpx 48rpx 0 0;
}

.edit-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 48rpx;
  border-bottom: 2rpx solid rgba(231, 229, 228, 0.6);
}

.edit-modal-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-main);
}

.edit-modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--text-muted);
}

.edit-modal-body {
  padding: 40rpx 48rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.edit-section {
  margin-bottom: 40rpx;
}

.edit-label {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 16rpx;
}

.avatar-edit {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #F5F5F4;
}

.btn-change-avatar {
  padding: 16rpx 32rpx;
  background: #F5F5F4;
  color: #E76F51;
  border: 2rpx solid rgba(231, 111, 81, 0.3);
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.btn-change-avatar::after {
  border: none;
}

.edit-input {
  width: 100%;
  padding: 24rpx 32rpx;
  background: #FAFAFA;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--text-main);
  border: 2rpx solid rgba(231, 229, 228, 0.6);
  box-sizing: border-box;
}

.edit-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx 32rpx;
  background: #FAFAFA;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--text-main);
  border: 2rpx solid rgba(231, 229, 228, 0.6);
  box-sizing: border-box;
  line-height: 1.6;
}

.edit-modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 48rpx 48rpx;
  border-top: 2rpx solid rgba(231, 229, 228, 0.6);
}

.btn-cancel,
.btn-save {
  flex: 1;
  padding: 28rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.btn-cancel {
  background: #F5F5F4;
  color: var(--text-secondary);
  border: 2rpx solid rgba(231, 229, 228, 0.6);
}

.btn-cancel::after {
  border: none;
}

.btn-save {
  background: #E76F51;
  color: var(--surface-white);
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(231, 111, 81, 0.3);
}

.btn-save::after {
  border: none;
}

/* ===== 主页标签展示 ===== */
.profile-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  width: 100%;
}

.profile-tag-pill {
  font-size: 24rpx;
  font-weight: 600;
  color: #57534E;
  background: rgba(28, 25, 23, 0.07);
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  border: 1.5rpx solid rgba(28, 25, 23, 0.10);
  line-height: 1.4;
}
