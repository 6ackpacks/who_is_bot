/* pages/profile/profile.wxss */

/* ===== 颜色变量 ===== */
page {
  --bg: #F4F4F0;
  --white: #FFFFFF;
  --accent: #E76F51;
  --accent-dark: #D97757;
  --text-900: #1C1917;
  --text-500: #78716C;
  --text-400: #A8A29E;
  --text-300: #D6D3D1;
  --border: rgba(231, 229, 228, 0.6);
  --success-bg: #E8F8F5;
  --success-fg: #20C997;
  --error-bg: #FDEDEC;
  --error-fg: #E76F51;
  --red-light: #FEF2F2;
  --red-border: rgba(239, 68, 68, 0.12);
  --red-icon: #EF4444;
}

/* ===== 容器 ===== */
.profile-container {
  width: 100%;
  min-height: 100vh;
  background: var(--bg);
}

.profile-scroll {
  width: 100%;
  height: 100vh;
}

/* ===== 顶部导航栏 ===== */
.profile-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 48rpx 28rpx;
  background: var(--bg);
}

.profile-nav-title {
  font-size: 60rpx;
  font-weight: 900;
  color: var(--text-900);
  letter-spacing: -2rpx;
  line-height: 1.1;
  font-family: Georgia, "Times New Roman", serif;
}

.profile-nav-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nav-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 编辑资料按钮：白色胶囊 */
.nav-btn-edit {
  padding: 16rpx 32rpx;
  background: var(--white);
  border-radius: 999rpx;
  border: 2rpx solid #E7E5E4;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.nav-btn-edit:active {
  background: #F5F5F4;
}

/* 退出按钮：红色圆形 */
.nav-btn-logout {
  width: 68rpx;
  height: 68rpx;
  background: var(--red-light);
  border-radius: 50%;
  border: 2rpx solid var(--red-border);
}

.nav-btn-logout:active {
  background: #FEE2E2;
}

/* 登录按钮：橙色胶囊 */
.nav-btn-login {
  padding: 16rpx 32rpx;
  background: var(--accent);
  border-radius: 999rpx;
}

.nav-btn-login:active {
  background: var(--accent-dark);
}

.nav-btn-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-500);
  line-height: 1;
}

.nav-btn-text-login {
  color: var(--white);
}

.nav-btn-logout-icon {
  font-size: 30rpx;
  color: var(--red-icon);
  line-height: 1;
}

/* ===== 个人信息头区域（白色卡片，底部大圆角） ===== */
.profile-header-card {
  background: var(--white);
  padding: 40rpx 48rpx 56rpx;
  border-radius: 0 0 80rpx 80rpx;
  box-shadow: 0 16rpx 48rpx -16rpx rgba(0, 0, 0, 0.08);
}

/* 头像 + 昵称行 */
.user-core-info {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.avatar-wrapper {
  position: relative;
  margin-bottom: 28rpx;
}

.user-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 6rpx solid var(--white);
  background: #F5F5F4;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.12);
  display: block;
}

/* 在线状态绿点 */
.avatar-status-dot {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 24rpx;
  height: 24rpx;
  background: #10B981;
  border: 4rpx solid var(--white);
  border-radius: 50%;
}

.profile-nickname {
  font-size: 56rpx;
  font-weight: 900;
  color: var(--text-900);
  line-height: 1.15;
  letter-spacing: -1.5rpx;
  font-family: Georgia, "Times New Roman", serif;
}

/* 个人简介 */
.profile-bio {
  font-size: 28rpx;
  color: #57534E;
  line-height: 1.9;
  letter-spacing: 1rpx;
  margin-bottom: 32rpx;
  width: 100%;
  display: block;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 无简介占位 */
.status-spacer {
  width: 100%;
  padding: 16rpx 0 24rpx;
  display: flex;
  align-items: center;
}

.status-spacer-text {
  font-size: 26rpx;
  color: #C4BFBB;
  font-style: italic;
  line-height: 1.5;
}

/* ===== 标签 ===== */
.profile-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  width: 100%;
  margin-bottom: 40rpx;
}

.profile-tag-pill {
  font-size: 22rpx;
  font-weight: 600;
  color: #57534E;
  background: rgba(28, 25, 23, 0.06);
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  border: 1.5rpx solid rgba(28, 25, 23, 0.09);
  line-height: 1.4;
}

/* ===== 数据统计卡片 ===== */
.stats-cards {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 12rpx;
  background: var(--white);
  border: 2rpx solid rgba(231, 229, 228, 0.7);
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stat-card:active {
  background: #FAFAFA;
}

.stat-card-number {
  font-size: 44rpx;
  font-weight: 900;
  color: var(--text-900);
  margin-bottom: 8rpx;
  line-height: 1.15;
  letter-spacing: -1rpx;
  font-family: Georgia, "Times New Roman", serif;
}

.stat-number-accent {
  color: var(--accent);
}

.stat-number-dark {
  color: var(--text-900);
}

.stat-card-label {
  font-size: 20rpx;
  color: var(--text-400);
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

/* ===== 标签页 ===== */
.tabs-container {
  margin-top: 0;
}

.tabs-header {
  background: rgba(244, 244, 240, 0.95);
  display: flex;
  align-items: stretch;
  padding: 0 32rpx;
  border-bottom: 2rpx solid rgba(231, 229, 228, 0.5);
  position: relative;
}

/* 原有 tabIndicator 隐藏（改用 tab-underline 元素实现） */
.tab-indicator {
  display: none;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 8rpx 0;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-400);
  padding-bottom: 20rpx;
  line-height: 1;
}

.tab-active .tab-text {
  color: var(--text-900);
  font-weight: 900;
}

/* 激活 tab 下的橙色下划线 */
.tab-underline {
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 6rpx;
  background: var(--accent);
  border-radius: 3rpx 3rpx 0 0;
}

/* ===== Tab 内容区 ===== */
.tab-content {
  min-height: 400rpx;
  padding: 24rpx 32rpx 32rpx;
  background: transparent;
}

/* ===== 判定记录列表 ===== */
.judgment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.judgment-item {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 24rpx;
  background: var(--white);
  border-radius: 24rpx;
  border: 2rpx solid rgba(245, 245, 244, 1);
  box-shadow: 0 4rpx 16rpx -8rpx rgba(0, 0, 0, 0.07);
}

.judgment-item:active {
  background: #FAFAFA;
}

/* 缩略图基础 */
.judgment-thumbnail {
  width: 128rpx;
  height: 128rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #F5F5F4;
  overflow: hidden;
  object-fit: cover;
}

/* 文字类缩略图 */
.thumb-text {
  background: linear-gradient(145deg, #1C1917 0%, #2D2926 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx;
  box-sizing: border-box;
}

.thumb-text-content {
  font-size: 17rpx;
  color: rgba(255, 255, 255, 0.82);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-align: center;
  letter-spacing: 0.5rpx;
}

/* 视频类缩略图 */
.thumb-video {
  position: relative;
  background: #1C1917;
}

.thumb-video-img {
  width: 128rpx;
  height: 128rpx;
  display: block;
}

.thumb-video-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.32);
}

.thumb-video-play {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 判定内容区 */
.judgment-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 14rpx;
  min-width: 0;
}

.judgment-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-900);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.judgment-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
}

/* 正确/错误标签 */
.judgment-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.badge-correct {
  background: var(--success-bg);
  color: var(--success-fg);
}

.badge-incorrect {
  background: var(--error-bg);
  color: var(--error-fg);
}

.badge-icon {
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1;
}

.badge-text {
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
}

.judgment-time {
  font-size: 20rpx;
  color: var(--text-400);
  font-weight: 500;
}

/* 右侧箭头 */
.judgment-chevron {
  font-size: 40rpx;
  color: var(--text-300);
  font-weight: 300;
  flex-shrink: 0;
  line-height: 1;
}

/* ===== 评论列表 ===== */
.comment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.comment-item {
  padding: 32rpx;
  background: var(--white);
  border-radius: 24rpx;
  border: 2rpx solid rgba(245, 245, 244, 1);
  box-shadow: 0 4rpx 16rpx -8rpx rgba(0, 0, 0, 0.07);
}

.comment-item:active {
  background: #FAFAFA;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.comment-content-title {
  font-size: 24rpx;
  color: var(--text-500);
  font-weight: 600;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.comment-time {
  font-size: 20rpx;
  color: var(--text-400);
  flex-shrink: 0;
}

.comment-text {
  font-size: 28rpx;
  color: var(--text-900);
  line-height: 1.65;
  margin-bottom: 16rpx;
}

.comment-footer {
  display: flex;
  justify-content: flex-end;
}

.comment-likes {
  font-size: 24rpx;
  color: var(--accent);
  font-weight: 700;
}

/* ===== 申请提交表单 ===== */
.submit-form {
  padding: 8rpx 0;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-900);
  margin-bottom: 16rpx;
}

.picker-view {
  padding: 24rpx 32rpx;
  background: var(--white);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--text-900);
  border: 2rpx solid var(--border);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.form-input {
  width: 100%;
  padding: 24rpx 32rpx;
  background: var(--white);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--text-900);
  border: 2rpx solid var(--border);
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx 32rpx;
  background: var(--white);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--text-900);
  border: 2rpx solid var(--border);
  box-sizing: border-box;
  line-height: 1.65;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: var(--text-400);
  margin-top: 8rpx;
}

.btn-submit {
  width: 100%;
  padding: 32rpx;
  background: var(--accent);
  color: var(--white);
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  margin-top: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(231, 111, 81, 0.32);
}

.btn-submit::after {
  border: none;
}

.btn-submit:active {
  background: var(--accent-dark);
}

/* ===== 空状态 ===== */
.empty-state {
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-400);
  font-weight: 500;
}

/* ===== 底部占位 ===== */
.bottom-spacer {
  height: 160rpx;
}

/* ===== 编辑资料弹窗 ===== */
.edit-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
}

.edit-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.45);
}

.edit-modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  max-height: 80vh;
  background: var(--white);
  border-radius: 48rpx 48rpx 0 0;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.1);
}

.edit-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 48rpx;
  border-bottom: 2rpx solid var(--border);
}

.edit-modal-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-900);
}

.edit-modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--text-400);
}

.edit-modal-body {
  padding: 40rpx 48rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.edit-section {
  margin-bottom: 40rpx;
}

.edit-label {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-900);
  margin-bottom: 16rpx;
}

.avatar-edit {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #F5F5F4;
}

.btn-change-avatar {
  padding: 16rpx 32rpx;
  background: #F5F5F4;
  color: var(--accent);
  border: 2rpx solid rgba(231, 111, 81, 0.28);
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.btn-change-avatar::after {
  border: none;
}

.edit-input {
  width: 100%;
  padding: 24rpx 32rpx;
  background: #FAFAFA;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--text-900);
  border: 2rpx solid var(--border);
  box-sizing: border-box;
}

.edit-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx 32rpx;
  background: #FAFAFA;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--text-900);
  border: 2rpx solid var(--border);
  box-sizing: border-box;
  line-height: 1.65;
}

.edit-modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 48rpx 48rpx;
  border-top: 2rpx solid var(--border);
}

.btn-cancel,
.btn-save {
  flex: 1;
  padding: 28rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.btn-cancel {
  background: #F5F5F4;
  color: var(--text-500);
  border: 2rpx solid var(--border);
}

.btn-cancel::after {
  border: none;
}

.btn-save {
  background: var(--accent);
  color: var(--white);
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(231, 111, 81, 0.3);
}

.btn-save::after {
  border: none;
}
