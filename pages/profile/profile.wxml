<!--pages/profile/profile.wxml-->
<view class="profile-container">
  <scroll-view scroll-y class="profile-scroll">

    <!-- 顶部导航栏 -->
    <view class="profile-nav">
      <text class="profile-nav-title">{{isOwnProfile ? '我的' : userInfo.nickname}}</text>
      <view class="profile-nav-actions" wx:if="{{isOwnProfile && isLoggedIn}}">
        <view class="nav-btn nav-btn-edit" bindtap="handleEditProfile">
          <text class="nav-btn-text">编辑资料</text>
        </view>
        <view class="nav-btn nav-btn-logout" bindtap="handleLogout">
          <text class="nav-btn-logout-icon">↪</text>
        </view>
      </view>
      <view class="profile-nav-actions" wx:elif="{{isOwnProfile && !isLoggedIn}}">
        <view class="nav-btn nav-btn-login" bindtap="handleEditProfile">
          <text class="nav-btn-text nav-btn-text-login">登录</text>
        </view>
      </view>
    </view>

    <!-- 个人信息头区域 -->
    <view class="profile-header-card">

      <!-- 头像 + 昵称 -->
      <view class="user-core-info">
        <view class="avatar-wrapper">
          <image
            src="{{userInfo.avatar}}"
            class="user-avatar"
            mode="aspectFill"
            binderror="handleAvatarError">
          </image>
          <view class="avatar-status-dot"></view>
        </view>
        <text class="profile-nickname">{{userInfo.nickname}}</text>
      </view>

      <!-- 个人简介 -->
      <text wx:if="{{userInfo.bio}}" class="profile-bio" decode="{{true}}">{{userInfo.bio}}</text>
      <view wx:else class="status-spacer">
        <text class="status-spacer-text">这个人有点懒，什么都没有留下。</text>
      </view>

      <!-- 标签 -->
      <view wx:if="{{userInfo.tags && userInfo.tags.length > 0}}" class="profile-tags">
        <text
          wx:for="{{userInfo.tags}}"
          wx:key="index"
          class="profile-tag-pill">{{item}}</text>
      </view>

      <!-- 核心数据统计 -->
      <view class="stats-cards">
        <view class="stat-card" bindtap="handleStatClick" data-type="judgments">
          <text class="stat-card-number stat-number-dark">{{judgmentStats.total || 0}}</text>
          <text class="stat-card-label">次判断</text>
        </view>
        <view class="stat-card" bindtap="handleStatClick" data-type="accuracy">
          <text class="stat-card-number stat-number-accent">{{judgmentStats.accuracy || 0}}%</text>
          <text class="stat-card-label">正确率</text>
        </view>
        <view class="stat-card" bindtap="handleStatClick" data-type="liked-comments">
          <text class="stat-card-number stat-number-dark">{{commentStats.totalLikes || 0}}</text>
          <text class="stat-card-label">被点赞评论</text>
        </view>
      </view>

    </view>

    <!-- 标签页 -->
    <view class="tabs-container">

      <!-- Tabs 导航 -->
      <view class="tabs-header">
        <view
          class="tab-item {{activeTab === 'judgments' ? 'tab-active' : ''}}"
          bindtap="switchTab"
          data-tab="judgments">
          <text class="tab-text">判定记录</text>
          <view class="tab-underline" wx:if="{{activeTab === 'judgments'}}"></view>
        </view>
        <view
          class="tab-item {{activeTab === 'comments' ? 'tab-active' : ''}}"
          bindtap="switchTab"
          data-tab="comments">
          <text class="tab-text">评论</text>
          <view class="tab-underline" wx:if="{{activeTab === 'comments'}}"></view>
        </view>
        <view
          class="tab-item {{activeTab === 'submit' ? 'tab-active' : ''}}"
          bindtap="switchTab"
          data-tab="submit">
          <text class="tab-text">申请提交</text>
          <view class="tab-underline" wx:if="{{activeTab === 'submit'}}"></view>
        </view>
        <!-- 保留原有 tabIndicator 兼容 JS -->
        <view class="tab-indicator" style="left: {{tabIndicatorLeft}}%; width: {{tabIndicatorWidth}}%;"></view>
      </view>

      <!-- 判定记录标签页 -->
      <view class="tab-content" wx:if="{{activeTab === 'judgments'}}">
        <view wx:if="{{judgments.length > 0}}" class="judgment-list">
          <view
            wx:for="{{judgments}}"
            wx:key="id"
            class="judgment-item"
            bindtap="goToDetail"
            data-id="{{item.contentId}}">

            <!-- 缩略图 -->
            <view wx:if="{{item.contentType === 'text'}}" class="judgment-thumbnail thumb-text">
              <text class="thumb-text-content">{{item.textSnippet}}</text>
            </view>
            <image
              wx:elif="{{item.contentType === 'image'}}"
              src="{{item.thumbnail}}"
              class="judgment-thumbnail"
              mode="aspectFill">
            </image>
            <view wx:else class="judgment-thumbnail thumb-video">
              <image src="/images/video-thumb.png" class="thumb-video-img" mode="aspectFill"></image>
              <view class="thumb-video-overlay">
                <text class="thumb-video-play">▶</text>
              </view>
            </view>

            <!-- 内容区 -->
            <view class="judgment-content">
              <view class="judgment-title">{{item.title}}</view>
              <view class="judgment-meta">
                <view class="judgment-badge {{item.isCorrect ? 'badge-correct' : 'badge-incorrect'}}">
                  <text class="badge-icon">{{item.isCorrect ? '✓' : '✗'}}</text>
                  <text class="badge-text">{{item.isCorrect ? '正确' : '错误'}}</text>
                </view>
                <text class="judgment-time">{{item.time}}</text>
              </view>
            </view>

            <!-- 右侧箭头 -->
            <text class="judgment-chevron">›</text>
          </view>
        </view>
        <view wx:else class="empty-state">
          <text class="empty-text">暂无判定记录</text>
        </view>
      </view>

      <!-- 评论标签页 -->
      <view class="tab-content" wx:if="{{activeTab === 'comments'}}">
        <view wx:if="{{comments.length > 0}}" class="comment-list">
          <view
            wx:for="{{comments}}"
            wx:key="id"
            class="comment-item"
            bindtap="goToDetail"
            data-id="{{item.contentId}}">
            <view class="comment-header">
              <text class="comment-content-title">{{item.contentTitle}}</text>
              <text class="comment-time">{{item.time}}</text>
            </view>
            <view class="comment-text">{{item.content}}</view>
            <view class="comment-footer">
              <text class="comment-likes">{{item.likes}} 赞</text>
            </view>
          </view>
        </view>
        <view wx:else class="empty-state">
          <text class="empty-text">暂无评论</text>
        </view>
      </view>

      <!-- 申请提交标签页 -->
      <view class="tab-content" wx:if="{{activeTab === 'submit'}}">
        <view class="submit-form">
          <view class="form-group">
            <text class="form-label">内容类型</text>
            <picker
              mode="selector"
              range="{{contentTypes}}"
              range-key="label"
              value="{{submitForm.typeIndex}}"
              bindchange="onContentTypeChange">
              <view class="picker-view">
                {{contentTypes[submitForm.typeIndex].label}}
              </view>
            </picker>
          </view>

          <view class="form-group">
            <text class="form-label">内容链接</text>
            <input
              class="form-input"
              placeholder="请输入内容链接"
              value="{{submitForm.url}}"
              bindinput="onUrlInput" />
          </view>

          <view class="form-group">
            <text class="form-label">说明</text>
            <textarea
              class="form-textarea"
              placeholder="请简要说明内容来源和特点"
              value="{{submitForm.description}}"
              bindinput="onDescriptionInput"
              maxlength="500" />
            <text class="char-count">{{submitForm.description.length}}/500</text>
          </view>

          <button class="btn-submit" bindtap="handleSubmitContent">提交申请</button>
        </view>
      </view>

    </view>

    <!-- 底部占位 -->
    <view class="bottom-spacer"></view>

  </scroll-view>

  <!-- 编辑资料弹窗 -->
  <view class="edit-modal" wx:if="{{showEditModal}}">
    <view class="edit-modal-mask" bindtap="closeEditModal"></view>
    <view class="edit-modal-content">
      <view class="edit-modal-header">
        <text class="edit-modal-title">编辑资料</text>
        <view class="edit-modal-close" bindtap="closeEditModal">✕</view>
      </view>

      <view class="edit-modal-body">
        <!-- 头像编辑 -->
        <view class="edit-section">
          <text class="edit-label">头像</text>
          <view class="avatar-edit">
            <image src="{{editForm.avatar}}" class="avatar-preview" mode="aspectFill"></image>
            <button class="btn-change-avatar" bindtap="handleChangeAvatar">更换头像</button>
          </view>
        </view>

        <!-- 昵称编辑 -->
        <view class="edit-section">
          <text class="edit-label">昵称</text>
          <input
            class="edit-input"
            placeholder="请输入昵称"
            value="{{editForm.nickname}}"
            bindinput="onNicknameInput"
            maxlength="20" />
        </view>

        <!-- 简介编辑 -->
        <view class="edit-section">
          <text class="edit-label">简介</text>
          <textarea
            class="edit-textarea"
            placeholder="介绍一下自己吧"
            value="{{editForm.bio}}"
            bindinput="onBioInput"
            maxlength="100" />
          <text class="char-count">{{editForm.bio.length}}/100</text>
        </view>
      </view>

      <view class="edit-modal-footer">
        <button class="btn-cancel" bindtap="closeEditModal">取消</button>
        <button class="btn-save" bindtap="handleSaveProfile">保存</button>
      </view>
    </view>
  </view>

</view>
