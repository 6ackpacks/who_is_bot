/* pages/notifications/notifications.wxss */

.notifications-container {
  width: 100%;
  min-height: 100vh;
  background: #F4F4F0;
}

/* 加载状态 */
.loading-container {
  width: 100%;
  height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #E7E5E4;
  border-top-color: #D97757;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 32rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #78716C;
}

/* 分区筛选 */
.section-tabs {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 16rpx;
  background: #F4F4F0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.section-tab {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #78716C;
  background: #FFFFFF;
  border: 2rpx solid #E7E5E4;
  transition: all 0.2s;
}

.section-tab-active {
  background: #1D1C16;
  color: #FFFFFF;
  border-color: #1D1C16;
}

/* 通知列表 */
.notification-list {
  height: calc(100vh - 120rpx);
  padding: 0 32rpx 120rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D1C16;
  margin-bottom: 16rpx;
  font-family: Georgia, 'Times New Roman', serif;
}

.empty-hint {
  font-size: 26rpx;
  color: #A8A29E;
  text-align: center;
  line-height: 1.6;
}

/* 通知项 */
.notification-item {
  display: flex;
  align-items: flex-start;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 2rpx solid #E7E5E4;
  position: relative;
}

.notification-unread {
  background: #FFFBF5;
  border-color: #F5D0B9;
}

.notification-item:active {
  background: #F5F5F4;
}

/* 类型图标 */
.notification-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #F5F5F4;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.notification-type-icon {
  font-size: 32rpx;
}

/* 通知内容 */
.notification-body {
  flex: 1;
  min-width: 0;
}

.notification-title {
  font-size: 28rpx;
  color: #1D1C16;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.notification-sender {
  font-weight: 600;
}

.notification-preview {
  font-size: 26rpx;
  color: #78716C;
  line-height: 1.4;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.notification-time {
  font-size: 24rpx;
  color: #A8A29E;
}

/* 未读圆点 */
.notification-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #E76F51;
  flex-shrink: 0;
  margin-left: 12rpx;
  margin-top: 8rpx;
}
