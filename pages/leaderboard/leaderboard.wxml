<!--pages/leaderboard/leaderboard.wxml - Podium Redesign-->
<view class="leaderboard-container">

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载排行榜中...</text>
  </view>

  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="error-container">
    <text class="error-text">{{error}}</text>
    <button class="retry-btn" bindtap="handleRetry">重新加载</button>
  </view>

  <!-- 排行榜内容 -->
  <scroll-view wx:else scroll-y class="leaderboard-content">

    <!-- 领奖台 - 前三名 -->
    <view class="podium-container">

      <!-- 第二名 (左侧) -->
      <view wx:if="{{users[1]}}" class="podium-item podium-second" bindtap="goToUserProfile" data-userid="{{users[1].id}}">
        <view class="podium-avatar-wrapper">
          <image src="{{users[1].avatar}}" class="podium-avatar avatar-second" mode="aspectFill" binderror="handleAvatarError" data-index="1"></image>
        </view>
        <view class="podium-base base-second">
          <text class="podium-rank rank-second">2</text>
        </view>
        <view class="podium-info">
          <text class="podium-name">{{users[1].username}}</text>
          <text class="podium-stats">准确率 {{users[1].accuracy}}%</text>
          <text class="podium-stats">{{users[1].totalJudged}} 题</text>
        </view>
      </view>

      <!-- 第一名 (中间) -->
      <view wx:if="{{users[0]}}" class="podium-item podium-first" bindtap="goToUserProfile" data-userid="{{users[0].id}}">
        <view class="crown-spacer"></view>
        <view class="crown-icon">👑</view>
        <view class="podium-avatar-wrapper">
          <image src="{{users[0].avatar}}" class="podium-avatar avatar-first" mode="aspectFill" binderror="handleAvatarError" data-index="0"></image>
        </view>
        <view class="podium-base base-first">
          <text class="podium-rank rank-first">1</text>
        </view>
        <view class="podium-info">
          <text class="podium-name">{{users[0].username}}</text>
          <text class="podium-stats">准确率 {{users[0].accuracy}}%</text>
          <text class="podium-stats">{{users[0].totalJudged}} 题</text>
        </view>
      </view>

      <!-- 第三名 (右侧) -->
      <view wx:if="{{users[2]}}" class="podium-item podium-third" bindtap="goToUserProfile" data-userid="{{users[2].id}}">
        <view class="podium-avatar-wrapper">
          <image src="{{users[2].avatar}}" class="podium-avatar avatar-third" mode="aspectFill" binderror="handleAvatarError" data-index="2"></image>
        </view>
        <view class="podium-base base-third">
          <text class="podium-rank rank-third">3</text>
        </view>
        <view class="podium-info">
          <text class="podium-name">{{users[2].username}}</text>
          <text class="podium-stats">准确率 {{users[2].accuracy}}%</text>
          <text class="podium-stats">{{users[2].totalJudged}} 题</text>
        </view>
      </view>

    </view>

    <!-- 排名卡片 - 第四名及以后 -->
    <view class="ranking-cards">
      <view wx:for="{{users}}" wx:key="id" wx:if="{{index >= 3}}" class="ranking-card" bindtap="goToUserProfile" data-userid="{{item.id}}">

        <!-- 排名数字 -->
        <text class="card-rank">{{index + 1}}</text>

        <!-- 头像 -->
        <image src="{{item.avatar}}" class="card-avatar" mode="aspectFill" binderror="handleAvatarError" data-index="{{index}}"></image>

        <!-- 用户信息 -->
        <view class="card-info">
          <text class="card-name">{{item.username}}</text>
          <text class="card-accuracy">准确率 {{item.accuracy}}%</text>
        </view>

        <!-- 统计数据 -->
        <view class="card-stats">
          <text class="card-score">{{item.totalJudged}}</text>
          <text class="card-label">题数</text>
        </view>

      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-spacer"></view>

  </scroll-view>

</view>
