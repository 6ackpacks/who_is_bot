/* pages/leaderboard/leaderboard.wxss - Claude-Inspired Podium Design */

/* ===== 容器 ===== */
.leaderboard-container {
  width: 100%;
  min-height: 100vh;
  background: var(--bg-primary, #F9F8F6);
  position: relative;
  overflow: hidden;
  padding-bottom: 120rpx;
}

/* ===== 加载状态 ===== */
.loading-container {
  width: 100%;
  height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 10;
  position: relative;
}

.loading-spinner {
  width: 100rpx;
  height: 100rpx;
  border: 8rpx solid var(--bg-secondary, #F0EEE6);
  border-top-color: var(--accent-clay, #D97757);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 40rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-main, #1D1C16);
  line-height: 1.6;
}

/* ===== 错误状态 ===== */
.error-container {
  width: 100%;
  height: 60vh;
  padding: 80rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 10;
  position: relative;
}

.error-text {
  font-size: 28rpx;
  color: var(--text-main, #1D1C16);
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.retry-btn {
  padding: 28rpx 72rpx;
  background: var(--accent-clay, #D97757);
  color: var(--surface-white, #FFFFFF);
  border-radius: 28rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  line-height: 1.6;
}

.retry-btn::after {
  border: none;
}

/* ===== 排行榜内容 ===== */
.leaderboard-content {
  height: calc(100vh - 120rpx);
  padding: 0 48rpx;
  box-sizing: border-box;
}

/* ===== 领奖台容器 ===== */
.podium-container {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 32rpx;
  padding-top: 32rpx;
  height: auto;
  min-height: 520rpx;
  overflow: visible;
  margin-bottom: 48rpx;
}

/* ===== 领奖台项目 ===== */
.podium-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  transition: all 0.2s ease-in-out;
}

.podium-item:active {
  transform: scale(0.95);
  opacity: 0.8;
}

/* 第一名 */
.podium-first {
  z-index: 3;
}

/* 第二名 */
.podium-second {
  z-index: 2;
}

/* 第三名 */
.podium-third {
  z-index: 1;
}

/* ===== 皇冠占位 ===== */
.crown-spacer {
  height: 80rpx;
  display: block;
}

/* ===== 皇冠图标 ===== */
.crown-icon {
  position: absolute;
  top: -64rpx;
  font-size: 48rpx;
  z-index: 10;
  animation: float 3s ease-in-out infinite;
}

/* ===== 头像容器 ===== */
.podium-avatar-wrapper {
  margin-bottom: 16rpx;
}

/* 头像样式 */
.podium-avatar {
  border-radius: 50%;
  object-fit: cover;
  display: block;
}

/* 第一名头像 */
.avatar-first {
  width: 160rpx;
  height: 160rpx;
  border: 6rpx solid var(--accent-clay, #D97757);
  box-shadow: 0 8rpx 12rpx -2rpx rgba(26, 26, 26, 0.3);
}

/* 第二名头像 */
.avatar-second {
  width: 128rpx;
  height: 128rpx;
  border: 4rpx solid var(--border-subtle, #E8E6DC);
  box-shadow: 0 8rpx 12rpx -2rpx rgba(0, 0, 0, 0.05);
}

/* 第三名头像 */
.avatar-third {
  width: 128rpx;
  height: 128rpx;
  border: 4rpx solid var(--text-muted, #66655F);
  box-shadow: 0 8rpx 12rpx -2rpx rgba(0, 0, 0, 0.05);
}

/* ===== 领奖台底座 ===== */
.podium-base {
  width: 100%;
  border-radius: 16rpx 16rpx 0 0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

/* 第一名底座 */
.base-first {
  height: 256rpx;
  background: linear-gradient(180deg, var(--accent-clay, #D97757) 0%, #2C2C2C 100%);
  box-shadow: 0 8rpx 12rpx -2rpx rgba(26, 26, 26, 0.3);
}

/* 第二名底座 */
.base-second {
  height: 192rpx;
  background: #E8E6DC;
  box-shadow: 0 8rpx 12rpx -2rpx rgba(0, 0, 0, 0.05);
}

/* 第三名底座 */
.base-third {
  height: 160rpx;
  background: var(--text-muted, #66655F);
  box-shadow: 0 8rpx 12rpx -2rpx rgba(0, 0, 0, 0.05);
}

/* ===== 排名数字 ===== */
.podium-rank {
  font-family: var(--font-display, 'Poppins', 'PingFang SC', -apple-system, sans-serif);
  font-weight: 700;
  text-align: center;
}

/* 第一名排名 */
.rank-first {
  font-size: 144rpx;
  color: var(--surface-white, #FFFFFF);
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

/* 第二名排名 */
.rank-second {
  font-size: 72rpx;
  color: var(--text-muted, #66655F);
}

/* 第三名排名 */
.rank-third {
  font-size: 72rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ===== 领奖台用户信息 ===== */
.podium-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  margin-top: 16rpx;
  width: 100%;
  padding: 0 8rpx;
}

.podium-name {
  font-family: var(--font-body, 'Lora', 'Noto Serif SC', Georgia, serif);
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-main, #0A0A0A);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
  line-height: 1.6;
}

.podium-stats {
  font-family: var(--font-body, 'Lora', 'Noto Serif SC', Georgia, serif);
  font-size: 20rpx;
  color: var(--text-muted, #3A3A3A);
  text-align: center;
  line-height: 1.4;
}

.podium-stats:first-of-type {
  color: #E76F51;
}

/* ===== 排名卡片容器 ===== */
.ranking-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ===== 排名卡片 ===== */
.ranking-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx;
  background: var(--surface-white, #FFFFFF);
  border: 2rpx solid var(--border-subtle, #E8E6DC);
  border-radius: 32rpx;
  box-shadow: 0 8rpx 12rpx -2rpx rgba(0, 0, 0, 0.05), 0 4rpx 8rpx -2rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s ease-in-out;
}

.ranking-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 8rpx -2rpx rgba(0, 0, 0, 0.05);
}

/* ===== 卡片排名数字 ===== */
.card-rank {
  font-family: var(--font-display, 'Poppins', 'PingFang SC', -apple-system, sans-serif);
  font-size: 56rpx;
  font-weight: 600;
  color: var(--text-muted, #66655F);
  width: 80rpx;
  text-align: center;
  flex-shrink: 0;
}

/* ===== 卡片头像 ===== */
.card-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
}

/* ===== 卡片信息 ===== */
.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.card-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main, #1D1C16);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.6;
}

.card-accuracy {
  font-size: 24rpx;
  color: #66655F;
  line-height: 1.6;
}

/* ===== 卡片统计 ===== */
.card-stats {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  flex-shrink: 0;
}

.card-score {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--accent-clay, #D97757);
}

.card-label {
  font-size: 20rpx;
  color: var(--text-muted, #66655F);
}

/* ===== 底部占位 ===== */
.bottom-spacer {
  height: 100rpx;
}

/* ===== 动画 ===== */
@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-12rpx);
  }
}
