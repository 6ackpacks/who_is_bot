<!--pages/feed/feed.wxml - 新版卡片式设计-->
<view class="feed-container theme-{{currentTheme}}">

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="error-container">
    <text class="icon icon-warning icon-xxl icon-warning"></text>
    <text class="error-text">{{error}}</text>
    <button class="retry-btn" bindtap="loadFeedData">重新加载</button>
  </view>

  <!-- 主内容区域 -->
  <view wx:if="{{viewState === 'judging'}}" class="judgment-view">

      <!-- 标题 -->
      <view class="page-title">谁是人机?</view>

      <!-- 内容区域（引号+卡片） -->
      <view class="content-wrapper">
        <view class="quote-icon">"</view>

        <!-- 视频内容 -->
        <view wx:if="{{currentItem.type === 'video'}}" class="content-card image-card {{cardSwipeClass}}">
          <view class="content-image-wrapper">
            <video
              id="content-video"
              class="content-video"
              src="{{currentItem.url}}"
              object-fit="contain"
              autoplay="{{true}}"
              loop="{{true}}"
              muted="{{true}}"
              show-center-play-btn="{{false}}"
              show-play-btn="{{false}}"
              controls="{{true}}"
              bindplay="onVideoPlay"
              bindpause="onVideoPause"
              binderror="onVideoError"
            ></video>
          </view>
        </view>

        <!-- 图片内容 -->
        <view wx:elif="{{currentItem.type === 'image'}}" class="content-card image-card {{cardSwipeClass}}">
          <view class="content-image-wrapper">
            <image class="content-image" src="{{currentItem.url}}" mode="aspectFit"></image>
          </view>
        </view>

        <!-- 文字内容 -->
        <view wx:else class="content-card {{cardSwipeClass}}">
          <text class="content-text">{{currentItem.text || currentItem.title}}</text>
        </view>
      </view>

      <!-- 判定按钮 -->
      <view class="action-buttons {{isItemJudged(currentItem.id) ? 'judged' : ''}}">
        <button
          class="btn-judge btn-ai {{isItemJudged(currentItem.id) ? 'judged' : ''}} {{getUserChoice(currentItem.id) === 'ai' ? 'user-choice' : ''}}"
          bindtap="handleJudge"
          data-choice="ai"
        >
          <text class="btn-icon">AI</text>
          <text class="btn-text">铁是人机</text>
        </button>
        <button
          class="btn-judge btn-human {{isItemJudged(currentItem.id) ? 'judged' : ''}} {{getUserChoice(currentItem.id) === 'human' ? 'user-choice' : ''}}"
          bindtap="handleJudge"
          data-choice="human"
        >
          <text class="btn-icon">人</text>
          <text class="btn-text">包是真人</text>
        </button>
      </view>

      <!-- 查看解析按钮（仅已判断时显示） -->
      <view wx:if="{{isItemJudged(currentItem.id)}}" class="view-analysis-container">
        <button class="btn-view-analysis" bindtap="viewAnalysis">
          查看解析
        </button>
      </view>

  </view>

  <!-- 判定后状态 - 评论/结果页面 -->
  <view wx:elif="{{viewState === 'revealed'}}" class="result-view">

      <!-- 返回按钮 - 左上角 -->
      <view class="back-button" bindtap="goHome">
        <text class="back-icon">←</text>
        <text class="back-text">返回</text>
      </view>

      <!-- 继续按钮 - 右上角 -->
      <view class="next-button" bindtap="handleNext">
        <text class="next-text">继续</text>
        <text class="next-icon">→</text>
      </view>

      <!-- 判定结果 - 极简标题展示 -->
      <view class="judgment-result-hero {{isCorrect ? 'correct' : 'incorrect'}}">
        <view class="result-headline">
          <text class="status-icon">{{isCorrect ? '✓' : '✗'}}</text>
          <text class="status-text">{{isCorrect ? '判定成功' : '判定失误'}}</text>
        </view>
        <view class="result-subtext">
          {{isCorrect ? '答对了' : '很遗憾'}}，这是<text class="highlight-type">"{{currentItem.isAi ? 'AI 生成' : '真人创作'}}"</text>
        </view>
      </view>

      <!-- 主内容白色卡片容器 -->
      <view class="result-content-card">
        <!-- 判定视觉容器 -->
        <view class="content-card">
          <view class="judgment-visual">
            <!-- 内容容器 - 9边形裁剪 -->
            <view class="content-image-container">
              <!-- 视频内容 -->
              <video
                wx:if="{{currentItem.type === 'video'}}"
                class="content-media"
                src="{{currentItem.url}}"
                object-fit="cover"
                autoplay="{{true}}"
                loop="{{true}}"
                muted="{{true}}"
                show-center-play-btn="{{false}}"
                show-play-btn="{{false}}"
                controls="{{true}}"
                bindplay="onVideoPlay"
                bindpause="onVideoPause"
                binderror="onVideoError"
              ></video>

              <!-- 图片内容 -->
              <image
                wx:elif="{{currentItem.type === 'image'}}"
                class="content-media"
                src="{{currentItem.url}}"
                mode="aspectFill"
              ></image>

              <!-- 文字内容 -->
              <view wx:else class="content-text-display">
                <text>{{currentItem.text || currentItem.title}}</text>
              </view>
            </view>

            <!-- 来源标签 -->
            <view class="tag-pill">
              <text class="tag-dot">●</text> 来源: {{currentItem.provider || currentItem.modelTag || 'Unknown'}}
            </view>
          </view>
        </view>



        <!-- 统计显示 - 优化版 -->
        <view class="stats-container">
          <view class="stat-main">
            <view class="stat-label">
              <text>全网共识度</text>
              <text class="stat-badge">{{currentItem.displayTotalVotes || currentItem.totalVotes || 12403}} 人参与</text>
            </view>
            <view class="stat-value">
              <text class="percentage-large">{{currentItem.displayAiPercent}}</text>
              <text class="percentage-unit">%</text>
              <text class="percentage-label">认为是AI</text>
            </view>
          </view>
          <view class="progress-track">
            <!-- AI侧：深色，左侧 -->
            <view class="progress-fill-ai" style="width: {{currentItem.displayAiPercent}}%; background: #1a1a1a;"></view>
            <!-- 真人侧：浅色，右侧 -->
            <view class="progress-fill-human" style="width: {{currentItem.displayHumanPercent}}%; background: #e0e0e0;"></view>
          </view>
          <view class="progress-labels">
            <text class="progress-label-item">AI {{currentItem.displayAiPercent}}%</text>
            <text class="progress-label-item">真人 {{currentItem.displayHumanPercent}}%</text>
          </view>
        </view>

        <!-- 解析卡片 -->
        <view wx:if="{{currentItem.explanation}}" class="analysis-card" bindtap="toggleAnalysis">
          <view class="analysis-header">
            <text class="analysis-title">⚡ 官方解析</text>
            <text class="chevron {{analysisExpanded ? 'expanded' : ''}}">›</text>
          </view>
          <view class="analysis-content {{analysisExpanded ? 'show' : ''}}">
            {{currentItem.explanation || '注意观察细节特征，AI生成的内容往往在光影、纹理等方面存在不自然的痕迹...'}}
          </view>
        </view>

        <!-- 评论区域 - REMOVED SORT TOGGLE -->
        <view class="comments-section">
        <view class="section-title-row">
          <view class="section-title">讨论 ({{comments.length}})</view>
        </view>

        <!-- 评论输入框 - 内联位置 -->
        <view class="comment-input-container">
          <input
            class="comment-input-field"
            placeholder="{{replyingTo ? '回复 ' + replyingTo.user.nickname : '发表你的观点...'}}"
            value="{{commentInput}}"
            bindinput="onCommentInput"
            maxlength="500"
            confirm-type="send"
            bindconfirm="submitComment"
          />
          <view class="comment-send-btn" bindtap="submitComment">
            <text class="send-icon">➤</text>
          </view>
        </view>

        <!-- 评论列表 -->
        <view class="comments-list">
          <view wx:if="{{comments.length === 0}}" class="empty-comments">
            <text class="empty-text">暂无评论，快来抢沙发吧~</text>
          </view>

          <block wx:for="{{comments}}" wx:key="id">
            <view class="comment-item">
              <!-- 用户头像 - 圆角方形 -->
              <image
                class="avatar"
                src="{{item.user ? item.user.avatar : 'https://api.dicebear.com/7.x/avataaars/svg?seed=default'}}"
                mode="aspectFill"
                binderror="handleAvatarError"
                data-index="{{index}}"
              />

              <view class="comment-body">
                <!-- 用户信息和时间 -->
                <view class="comment-meta">
                  <view class="username-row">
                    <text class="username">{{item.user ? item.user.nickname : '游客'}}</text>
                    <text wx:if="{{item.isPinned}}" class="pin-badge">精选</text>
                  </view>
                  <text class="comment-time">{{item.createdAt}}</text>
                </view>

                <!-- 评论内容 -->
                <view class="comment-text">{{item.content}}</view>

                <!-- 操作按钮 -->
                <view class="comment-actions">
                  <view class="action-btn" bindtap="onLikeComment" data-id="{{item.id}}">
                    <text class="like-icon">👍</text>
                    <text class="action-count">{{item.likes > 0 ? item.likes : '赞'}}</text>
                  </view>
                  <view class="action-btn" bindtap="onReplyComment" data-comment="{{item}}">
                    <text>回复</text>
                  </view>
                </view>
              </view>
            </view>
          </block>
        </view>
      </view>
      </view>
      <!-- 关闭主内容白色卡片容器 -->

  </view>

</view>
