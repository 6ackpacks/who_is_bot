  flex-direction: row;
}

/* AI侧：深色，左侧 */
.progress-fill-ai {
  height: 100%;
  background: #1a1a1a;
  border-radius: 8rpx 0 0 8rpx;
  position: relative;
  overflow: hidden;
  animation: progressGrow 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.5s backwards;
  flex-shrink: 0;
}

/* 真人侧：浅色，右侧 */
.progress-fill-human {
  height: 100%;
  background: #e0e0e0;
  border-radius: 0 8rpx 8rpx 0;
  position: relative;
  overflow: hidden;
  animation: progressGrow 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.5s backwards;
  flex-shrink: 0;
}

@keyframes progressGrow {
  0% { width: 0 !important; }
}

/* Shimmer effect on the AI (dark) side */
.progress-fill-ai::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 50%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: shimmer 2s linear 1.5s infinite;
  transform: skewX(-12deg);
}

@keyframes shimmer {
  0% { left: -100%; }
  100% { left: 200%; }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.anim-d0 { animation: fadeInUp 0.5s ease-out 0s both; }
.anim-d1 { animation: fadeInUp 0.5s ease-out 0.15s both; }
.anim-d2 { animation: fadeInUp 0.5s ease-out 0.3s both; }
.anim-d3 { animation: fadeInUp 0.5s ease-out 0.45s both; }
.anim-d4 { animation: fadeInUp 0.5s ease-out 0.6s both; }
.anim-d5 { animation: fadeInUp 0.5s ease-out 0.75s both; }

