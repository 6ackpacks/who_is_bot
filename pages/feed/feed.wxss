/* pages/feed/feed.wxss - Claude-Inspired Design */

/* ===== 容器 - Paper-like Background ===== */
.feed-container {
  width: 100vw;
  min-height: 100vh;
  background: var(--bg-primary, #F4F4F0);
  position: relative;
}

/* 背景装饰 - 柔和的装饰效果 (Claude风格 - 减少彩色) */
.feed-container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

/* Removed .feed-scroll - no longer needed */

/* ===== 加载状态 ===== */
.loading-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: transparent;
  animation: fadeIn 0.3s ease-out;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid var(--bg-secondary, #F0EEE6);
  border-top-color: var(--accent-clay, #D97757);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
  box-shadow: 0 0 20rpx rgba(26, 26, 26, 0.2);
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-main, #1D1C16);
  font-family: var(--font-body);
  animation: pulse 2s ease-in-out infinite;
  line-height: 1.6;
}

/* ===== 错误状态 ===== */
.error-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 60rpx;
  animation: fadeIn 0.3s ease-out;
}

.error-text {
  font-size: 28rpx;
  color: var(--text-main, #1D1C16);
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.8;
  font-family: var(--font-body);
  animation: slideInUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

.retry-btn {
  padding: 28rpx 72rpx;
  background: var(--accent-clay, #D97757);
  color: var(--surface-white, #FFFFFF);
  border-radius: var(--radius-pill);
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  font-family: var(--font-body);
  box-shadow: 0 8rpx 12rpx -2rpx rgba(0, 0, 0, 0.05), 0 4rpx 8rpx -2rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s ease-in-out;
  animation: slideInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  line-height: 1.6;
}

.retry-btn::after {
  border: none;
}

.retry-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 8rpx -2rpx rgba(0, 0, 0, 0.05);
}

/* ===== 判定视图 - 单屏布局优化 ===== */
.judgment-view {
  padding: 40rpx 32rpx 180rpx; /* 底部预留 Banner 安全区域 */
  height: 100vh;
  width: 100vw;
  display: flex;
  flex-direction: column;
  overflow: hidden; /* 禁止滚动 */
  box-sizing: border-box;
  animation: fadeIn 0.4s ease-out;
  position: fixed; /* 固定定位，完全不能滚动 */
  top: 0;
  left: 0;
}

/* 背景装饰 Blob (Claude风格 - 减少彩色) */
.judgment-view::before,
.judgment-view::after {
  content: '';
  position: absolute;
  border-radius: 40%;
  filter: blur(60rpx);
  z-index: 0;
  opacity: 0.08;
  animation: float 6s ease-in-out infinite;
  pointer-events: none;
}

.page-title {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--accent-clay, #D97757);
  text-align: center;
  margin-bottom: 20rpx;
  font-family: var(--font-display);
  flex-shrink: 0;
  animation: slideInDown 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  letter-spacing: -2rpx;
  position: relative;
  z-index: 1;
  height: auto;
  line-height: 1.6;
}

/* ===== 内容区域 - 弹性空间，自动压缩 ===== */
.content-wrapper {
  width: 100%;
  position: relative;
  flex: 1; /* 占据剩余空间 */
  display: flex;
  flex-direction: column;
  justify-content: center; /* 内容垂直居中 */
  min-height: 0; /* 允许内容压缩 */
  overflow: hidden;
  animation: scaleIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.1s backwards;
  z-index: 1;
}

.quote-icon {
  font-size: 60rpx;
  color: rgba(0, 0, 0, 0.08);
  font-family: Georgia, serif;
  font-weight: bold;
  line-height: 1;
  margin-bottom: 16rpx;
  padding-left: 20rpx;
  flex-shrink: 0;
  animation: fadeIn 0.4s ease-out 0.2s backwards;
}

/* ===== 内容卡片 - Claude风格，带卡片动画 ===== */
.content-card {
  background: var(--surface-white, #FFFFFF);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-soft, 28rpx);
  padding: 48rpx;
  box-shadow: 0 8rpx 12rpx -2rpx rgba(0, 0, 0, 0.05), 0 4rpx 8rpx -2rpx rgba(0, 0, 0, 0.03);
  border: 2rpx solid var(--border-subtle, #E8E6DC);
  position: relative;
  overflow-y: auto;
  flex: 0 0 auto; /* 文字卡片自适应高度 */
  min-height: 200rpx; /* 确保最小高度 */
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  animation: cardEnter 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s backwards;
  transform-origin: bottom center;
}

/* 结果视图中的内容卡片 - 移除高度限制和滚动 */
.result-view .content-card {
  align-items: flex-start;
  border: none;
  background: transparent;
  box-shadow: none;
  padding: 0 32rpx;
}

/* 判定页面的内容卡片 - 禁止内部滚动 */
.judgment-view .content-card {
  overflow: hidden;
  max-height: none;
}

/* 判定页面的文字内容 - 限制高度，内部滚动 */
.judgment-view .content-text {
  overflow-y: auto;
  max-height: 100%;
  display: block;
}

@keyframes cardEnter {
  0% {
    opacity: 0;
    transform: scale(0.5) translateY(100rpx);
  }
  100% {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.content-card:active {
  transform: scale(0.98);
}

/* 图片卡片 - 判定页面专用 */
.judgment-view .content-card.image-card {
  padding: 0;
  background: transparent;
  backdrop-filter: none;
  box-shadow: none;
  overflow: visible;
  border: none;
  position: relative;
  flex: 1; /* 图片/视频卡片占据剩余空间 */
  min-height: 0; /* 允许压缩 */
  display: flex;
  flex-direction: column;
}



.content-image-wrapper {
  position: relative;
  border-radius: var(--radius-soft, 28rpx);
  overflow: hidden;
  box-shadow: none; /* Fully removed shadow */
  border: none; /* Fully removed border */
  width: 100%;
  flex: 1; /* 占据剩余空间 */
  min-height: 0; /* 允许压缩 */
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent; /* No grey background */
  transition: none;
}

/* 判定页面的图片和视频 - 自适应压缩 */
.judgment-view .content-image {
  width: 100%;
  aspect-ratio: 1; /* maintain a default square height */
  height: auto;
  min-height: 480rpx; /* Prevent shrinking to 0 */
  display: block;
  object-fit: contain; /* 保持比例，不裁剪 */
  animation: fadeIn 0.5s ease-out;
}

.judgment-view .content-video {
  width: 100%;
  aspect-ratio: 1; /* Need exact layout box to show */
  height: auto;
  min-height: 480rpx;
  display: block;
  object-fit: contain; /* 保持比例，不裁剪 */
  background: var(--bg-dark); /* Show black bg for letterboxing */
  border-radius: var(--radius-soft);
}

/* 文字内容 */
.content-text {
  font-size: 32rpx;
  line-height: 1.8;
  color: var(--text-main, #1D1C16);
  font-family: var(--font-body);
  display: block;
  animation: fadeIn 0.5s ease-out 0.3s backwards;
  max-height: 100%; /* 限制最大高度 */
}

/* ===== 来源信息 ===== */
.source-info {
  font-size: 24rpx;
  color: #66655F;
  text-align: center;
  margin-bottom: 20rpx;
  margin-top: 24rpx;
  font-family: var(--font-body);
  animation: fadeIn 0.4s ease-out 0.3s backwards;
}

/* ===== 判定按钮 - 增加手机两边距防止溢出 ===== */
.action-buttons {
  display: flex;
  gap: 32rpx; /* Increased gap */
  width: 100%;
  padding: 0 64rpx; /* INCREASED PADDING TO PREVENT OVERFLOW */
  flex-shrink: 0;
  margin-top: 40rpx;
  justify-content: center;
  align-items: center;
  animation: slideInUp 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s backwards;
  position: relative;
  z-index: 1;
  height: 110rpx;
  box-sizing: border-box;
}

/* 已判断状态的按钮容器 */
.action-buttons.judged {
  opacity: 1;
}

.btn-judge {
  flex: 1; /* 占据可用空间 */
  max-width: 320rpx; /* 限制最大宽度 */
  height: 110rpx;
  border-radius: 28rpx;
  border: none;
  font-family: var(--font-body);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
  overflow: visible;
  flex-shrink: 0;
  box-sizing: border-box;
}

.btn-icon {
  font-size: 44rpx;
  line-height: 1;
  font-weight: 900;
  font-family: var(--font-display);
  color: #FFFFFF;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
  letter-spacing: -1rpx;
}

.btn-text {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 500;
  font-family: var(--font-body);
  line-height: 1.3;
  letter-spacing: 0.8rpx;
  margin-top: 4rpx;
}

.btn-judge::after {
  border: none;
}

.btn-judge:active {
  transform: scale(0.95);
}

/* 已判断的按钮样式（半透明） */
.btn-judge.judged {
  opacity: 0.4;
}

/* 用户选择标记（✓） - Claude风格 */
.btn-judge.user-choice::after {
  content: '✓';
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 52rpx;
  height: 52rpx;
  background: var(--bg-dark, #111111);
  color: var(--surface-white, #FFFFFF);
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  border: 4rpx solid var(--bg-primary, #F9F8F6);
  z-index: 10;
}

/* AI 按钮 - 深色背景 + 白色文字 (Claude风格) */
.btn-ai {
  background: linear-gradient(135deg, #66655F 0%, #1A1A1A 100%);
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
}

.btn-ai:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 4rpx -2rpx rgba(0, 0, 0, 0.15);
}

/* Human 按钮 - 深灰色背景 + 白色文字 (Claude风格) */
.btn-human {
  background: linear-gradient(135deg, #66655F 0%, #2A2A2A 100%);
  box-shadow: 0 4rpx 8rpx -2rpx rgba(0, 0, 0, 0.15);
}

.btn-human:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 4rpx -2rpx rgba(0, 0, 0, 0.15);
}

/* 查看解析按钮容器 - 固定高度，不压缩 */
.view-analysis-container {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
  flex-shrink: 0; /* 不压缩 */
  height: 96rpx; /* 固定高度 */
  animation: slideInUp 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.4s backwards;
}

/* 查看解析按钮 - Claude风格 */
.btn-view-analysis {
  width: 560rpx;
  height: 96rpx;
  background: var(--bg-dark, #111111);
  color: var(--bg-primary, #F9F8F6);
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  font-family: var(--font-body);
  box-shadow: 0 8rpx 12rpx -2rpx rgba(0, 0, 0, 0.1);
  transition: all 0.2s ease-in-out;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1.6;
}

.btn-view-analysis::after {
  border: none;
}

.btn-view-analysis:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 8rpx -2rpx rgba(0, 0, 0, 0.1);
}

/* ===== 结果视图 - 评论/结果页面 - 可以滚动 ===== */
.result-view {
  width: 100vw;
  min-height: 100vh;
  padding-bottom: 200rpx;
  animation: fadeIn 0.4s ease-out;
  display: flex;
  flex-direction: column;
  position: relative;
  background: #F4F4F0;
  /* 允许页面自然滚动，不设置 overflow */
}

/* Main result content wrapper - fits in viewport */
.result-main-content {
  flex: 0 0 auto;
  max-height: calc(100vh - 120rpx);
  display: flex;
  flex-direction: column;
}

/* 主内容白色卡片容器 - 浮动效果 */
.result-content-card {
  background: #FFFFFF;
  border-radius: var(--radius-large, 48rpx);
  margin: 0 32rpx 40rpx 32rpx;
  padding: 48rpx 0 0 0;
  box-shadow: var(--shadow-card, 0 40rpx 80rpx -30rpx rgba(0, 0, 0, 0.05));
  border: 2rpx solid rgba(241, 241, 235, 0.5);
  animation: fadeInUp 0.5s ease-out 0.3s both;
}

/* 统计卡片容器 - 内嵌在白色主卡片内 */
.result-stats-card {
  margin: 0 48rpx 48rpx 48rpx;
  background: #FAFAFA;
  border-radius: 48rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: inset 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  overflow: hidden;
  animation: fadeInUp 0.5s ease-out 0.4s both;
}

/* 返回按钮 - 左上角固定定位 - 优化为胶囊形状 */
.back-button {
  position: fixed;
  top: 100rpx;
  left: 32rpx;
  height: 80rpx;
  padding: 0 28rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 8rpx 12rpx -2rpx rgba(0, 0, 0, 0.05), 0 4rpx 8rpx -2rpx rgba(0, 0, 0, 0.03);
  z-index: 1000;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.back-button:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 8rpx -2rpx rgba(0, 0, 0, 0.05);
}

.back-icon {
  font-size: 32rpx;
  color: #1D1C16;
  font-weight: 600;
  line-height: 1;
}

.back-text {
  font-size: 28rpx;
  color: #1D1C16;
  font-weight: 500;
  line-height: 1;
}

/* 继续按钮 - 右上角固定定位 - 主要操作按钮 */
.next-button {
  position: fixed;
  top: 100rpx;
  right: 32rpx;
  height: 80rpx;
  padding: 0 28rpx;
  background: #1D1C16;
  backdrop-filter: blur(20rpx);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 8rpx 12rpx -2rpx rgba(0, 0, 0, 0.15), 0 4rpx 8rpx -2rpx rgba(0, 0, 0, 0.1);
  z-index: 1000;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.next-button:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 8rpx -2rpx rgba(0, 0, 0, 0.15);
}

.next-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
  line-height: 1;
}

.next-icon {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
  line-height: 1;
}

/* 判定结果 - 极简标题展示 - 优化版 */
.judgment-result-hero {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 200rpx 0 40rpx 0;
  padding: 0 40rpx;
  box-sizing: border-box;
  animation: resultReveal 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) backwards;
  z-index: 10;
}

@keyframes resultReveal {
  0% { opacity: 0; transform: scale(0.95) translateY(-10rpx); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

.result-headline {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  animation: fadeInUp 0.5s ease-out 0s both;
}

.status-icon {
  font-size: 64rpx;
  font-weight: 800;
  line-height: 1;
  animation: iconPop 0.4s cubic-bezier(0.16, 1, 0.3, 1) backwards;
}

/* Result icon animation - matches tolearn.md spec: scale 0.8→1, opacity 0→1 */
@keyframes iconPop {
  0% {
    opacity: 0;
    transform: scale(0.8);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.status-text {
  font-size: 60rpx;
  font-weight: 900;
  font-family: var(--font-display);
  letter-spacing: -2rpx;
  animation: textSlide 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s backwards;
}

@keyframes textSlide {
  0% { opacity: 0; transform: translateY(10rpx); }
  100% { opacity: 1; transform: translateY(0); }
}

.judgment-result-hero.correct .status-icon,
.judgment-result-hero.correct .status-text {
  color: var(--accent-success, #10b981);
}

.judgment-result-hero.incorrect .status-icon,
.judgment-result-hero.incorrect .status-text {
  color: var(--accent-error, #E76F51);
}

.result-subtext {
  text-align: center;
  font-size: 36rpx;
  color: var(--text-secondary, #78716C);
  font-family: var(--font-body);
  line-height: 1.6;
  animation: fadeInUp 0.5s ease-out 0.2s both;
}

.highlight-type {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-main, #1D1C16);
  font-family: var(--font-display);
  margin: 0 4rpx;
  padding: 4rpx 8rpx;
  position: relative;
}

.highlight-underline {
  border-bottom: 6rpx solid rgba(231, 111, 81, 0.25);
}

/* 内容卡片 - REDUCED BOTTOM MARGIN */
.content-card {
  margin: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: none;
}

/* 结果视图中的内容卡片 - 左对齐子元素 */
.result-view .content-card {
  align-items: flex-start;
  border: none;
  background: transparent;
  box-shadow: none;
  padding: 0 48rpx;
}

/* 判定视觉容器 - 固定1:1比例，参考learn-say.md */
.judgment-visual {
  width: 100%;
  position: relative;
  margin: 0 auto 32rpx auto;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 内容容器 - 移除原型限制，改为舒适圆角 */
.content-image-container {
  width: 100%;
  min-height: 400rpx;
  background-color: var(--surface-white, #FFFFFF);
  border-radius: var(--radius-large, 48rpx);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: inset 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border: none;
}

/* 媒体内容 - 4:3 比例 */
.content-media {
  width: 100%;
  aspect-ratio: 4/3;
  display: block;
  border-radius: var(--radius-large, 48rpx);
}

video.content-media {
  object-fit: contain; /* Video keep aspect ratio without cropping */
  background-color: var(--bg-dark);
}

image.content-media {
  object-fit: cover; /* Image can cover */
}

.content-text-display {
  width: 100%;
  height: auto;
  min-height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 110rpx 48rpx 48rpx 48rpx; /* Increased top padding to avoid overlapping the tag pill */
  box-sizing: border-box;
}

.content-text-display text {
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--text-main, #1D1C16);
  text-align: justify;
  font-family: var(--font-body);
  font-weight: 500;
  word-wrap: break-word;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 12;
  -webkit-box-orient: vertical;
  width: 100%;
}



/* 来源标签 - 毛玻璃质感优化 */
.tag-pill {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
