/* app.wxss - 全局样式 */
@import "styles/iconfont.wxss";
@import "styles/animations.wxss";

/* ===== Claude-Inspired Design System ===== */
page {
  /* Color Variables */
  --bg-primary: #F9F8F6;
  --bg-secondary: #F0EEE6;
  --accent-clay: #D97757;
  --text-main: #1D1C16;
  --text-muted: #66655F;
  --bg-dark: #111111;
  --surface-white: #FFFFFF;
  --border-subtle: #E8E6DC;

  /* Typography */
  --font-display: 'Poppins', 'PingFang SC', -apple-system, BlinkMacSystemFont, sans-serif;
  --font-body: 'Lora', 'Noto Serif SC', Georgia, serif;

  /* Spacing & Sizing */
  --radius-soft: 28rpx;
  --radius-pill: 999rpx;

  /* Shadows */
  --shadow-sm: 0 8rpx 12rpx -2rpx rgba(0, 0, 0, 0.05), 0 4rpx 8rpx -2rpx rgba(0, 0, 0, 0.03);
  --shadow-md: 0 8rpx 12rpx -2rpx rgba(0, 0, 0, 0.05), 0 4rpx 8rpx -2rpx rgba(0, 0, 0, 0.03);
  --shadow-lg: 0 8rpx 12rpx -2rpx rgba(0, 0, 0, 0.05), 0 4rpx 8rpx -2rpx rgba(0, 0, 0, 0.03);

  /* Easing Functions */
  --ease-elastic: cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-smooth: cubic-bezier(0.4, 0, 0.2, 1);

  /* Apply Global Theme */
  background-color: var(--bg-primary);
  font-family: var(--font-body);
  color: var(--text-main);
}

/* 全局图片样式 */
image {
  display: block;
}

/* 通用容器 */
.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 按钮样式 - Claude Theme */
.btn-primary {
  background-color: var(--accent-clay);
  color: var(--surface-white);
  border-radius: var(--radius-pill);
  padding: 28rpx 56rpx;
  font-weight: bold;
  font-size: 28rpx;
  border: none;
  transition: all 0.2s ease-in-out;
  line-height: 1.6;
}

.btn-primary:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.btn-secondary {
  background-color: var(--surface-white);
  color: var(--text-main);
  border: 2rpx solid var(--border-subtle);
  border-radius: var(--radius-pill);
  padding: 28rpx 56rpx;
  font-weight: bold;
  font-size: 28rpx;
  transition: all 0.2s ease-in-out;
  line-height: 1.6;
}

.btn-secondary:active {
  transform: scale(0.96);
  background-color: var(--bg-secondary);
}

/* 卡片样式 */
.card {
  background-color: var(--surface-white);
  border-radius: var(--radius-soft);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--border-subtle);
}

/* 文本样式 */
.text-primary {
  color: var(--text-main);
  line-height: 1.6;
}

.text-secondary {
  color: var(--text-muted);
  line-height: 1.6;
}

.text-muted {
  color: var(--text-muted);
  line-height: 1.6;
}

.text-bold {
  font-weight: bold;
}

/* ===== Typography Utilities ===== */
.font-serif-display {
  font-family: var(--font-display);
}

.font-display {
  font-family: var(--font-display);
}

.font-body {
  font-family: var(--font-body);
}

/* ===== Color Utilities ===== */
/* Text Colors */
.text-clay {
  color: var(--accent-clay);
}

.text-main {
  color: var(--text-main);
}

.text-muted {
  color: var(--text-muted);
}

.text-dark {
  color: var(--bg-dark);
}

/* Legacy color classes (for backward compatibility) */
.color-clay {
  color: var(--accent-clay);
}

/* Background Colors */
.bg-clay {
  background-color: var(--accent-clay);
}

.bg-primary {
  background-color: var(--bg-primary);
}

.bg-secondary {
  background-color: var(--bg-secondary);
}

.bg-white {
  background-color: var(--surface-white);
}

.bg-dark {
  background-color: var(--bg-dark);
}

/* ===== Shadow Utilities ===== */
.shadow-sm {
  box-shadow: var(--shadow-sm);
}

.shadow-md {
  box-shadow: var(--shadow-md);
}

.shadow-lg {
  box-shadow: var(--shadow-lg);
}

/* ===== Border Utilities ===== */
.border-soft {
  border-radius: var(--radius-soft);
}

.border-pill {
  border-radius: var(--radius-pill);
}

.border-clay {
  border-color: var(--accent-clay);
}

.border-subtle {
  border-color: var(--border-subtle);
}

/* ===== Animation Utilities ===== */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.animate-fade-in {
  animation: fadeIn 0.6s var(--ease-smooth) forwards;
}

.animate-slide-up {
  animation: slideInUp 0.6s var(--ease-smooth) forwards;
}

.animate-float {
  animation: float 6s ease-in-out infinite;
}

/* ===== Transition Utilities ===== */
.transition-smooth {
  transition: all 0.3s var(--ease-smooth);
}

.transition-elastic {
  transition: all 0.5s var(--ease-elastic);
}
