/* Size variants */
.antd-icon-xs {
  font-size: 20rpx;
}

.antd-icon-sm {
  font-size: 28rpx;
}

.antd-icon-md {
  font-size: 36rpx;
}

.antd-icon-lg {
  font-size: 48rpx;
}

.antd-icon-xl {
  font-size: 64rpx;
}

.antd-icon-xxl {
  font-size: 80rpx;
}

/* Color variants - must be in component WXSS for custom-class to work */
.icon-cyan {
  color: #00F2FF !important;
}

.icon-white {
  color: #FFFFFF !important;
}

.icon-locked {
  color: rgba(255, 255, 255, 0.3) !important;
}

.icon-unlocked {
  color: #00F2FF !important;
}

.icon-burgundy {
  color: #D97757 !important;
}

.icon-clay {
  color: #D97757 !important;
}
