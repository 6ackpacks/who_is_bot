/* iconfont.wxss - 专业图标字体系统 */
/* 使用更专业的 Unicode 字符 */

/* 图标字体基础类 */
.icon {
  display: inline-block;
  font-style: normal;
  line-height: 1;
  text-align: center;
  text-transform: none;
  vertical-align: baseline;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

/* 视频图标 */
.icon-video::before {
  content: '▶';
  font-size: 1.2em;
}

/* 图片图标 */
.icon-image::before {
  content: '🖼';
  font-size: 1em;
}

/* 文本图标 */
.icon-text::before {
  content: '📝';
  font-size: 1em;
}

/* 正确/成功图标 */
.icon-check::before {
  content: '✓';
  font-weight: bold;
}

/* 错误/失败图标 */
.icon-close::before {
  content: '✕';
  font-weight: bold;
}

/* 警告图标 */
.icon-warning::before {
  content: '⚠';
  font-size: 1.2em;
}

/* AI机器人图标 */
.icon-robot::before {
  content: '🤖';
  font-size: 1em;
}

/* 用户/真人图标 */
.icon-user::before {
  content: '👤';
  font-size: 1em;
}

/* 统计/图表图标 */
.icon-chart::before {
  content: '📊';
  font-size: 1em;
}

/* 眼睛图标 */
.icon-eye::before {
  content: '👁';
  font-size: 1em;
}

/* 闪电图标 */
.icon-thunder::before {
  content: '⚡';
  font-size: 1em;
}

/* 链接/分享图标 */
.icon-link::before {
  content: '🔗';
  font-size: 1em;
}

/* 锁定图标 */
.icon-lock::before {
  content: '🔒';
  font-size: 1em;
}

/* 右箭头 */
.icon-right::before {
  content: '›';
  font-size: 1.5em;
  font-weight: 300;
}

/* 加载/旋转图标 */
.icon-loading::before {
  content: '◐';
  animation: icon-spin 1s linear infinite;
}

@keyframes icon-spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

/* 火焰图标 */
.icon-fire::before {
