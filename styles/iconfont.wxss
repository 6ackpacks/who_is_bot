/* 图标尺寸变体 */
.icon-xs {
  font-size: 20rpx;
}

.icon-sm {
  font-size: 28rpx;
}

.icon-md {
  font-size: 36rpx;
}

.icon-lg {
  font-size: 48rpx;
}

.icon-xl {
  font-size: 64rpx;
}

.icon-xxl {
  font-size: 80rpx;
}

/* 图标颜色变体 */
.icon-primary {
  color: #3B82F6;
}

.icon-success {
  color: #10B981;
}

.icon-warning {
  color: #F59E0B;
}

.icon-danger {
  color: #EF4444;
}

.icon-info {
  color: #6B7280;
}

.icon-white {
  color: #FFFFFF;
}

.icon-black {
  color: var(--text-main, #1D1C16);
}

/* 图标交互效果 */
.icon-interactive {
  cursor: pointer;
  transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.icon-interactive:active {
  transform: scale(0.9);
}

/* 排行榜图标 */
.icon-rank::before {
  content: '📈';
  font-size: 1em;
}

/* 名片图标 */
.icon-card::before {
  content: '🎴';
  font-size: 1em;
}

/* 网格/更多图标 */
.icon-grid::before {
  content: '⊞';
  font-size: 1.2em;
}

/* 月亮/暗色模式图标 */
.icon-moon::before {
  content: '🌙';
  font-size: 1em;
}

/* 太阳/亮色模式图标 */
.icon-sun::before {
  content: '☀';
  font-size: 1.1em;
}

/* 设置图标（别名） */
.icon-settings::before {
  content: '⚙';
  font-size: 1.2em;
}

/* 信息图标 */
.icon-info::before {
  content: 'ℹ';
  font-size: 1.2em;
  font-weight: bold;
}

/* 正确圆圈图标 */
.icon-check-circle::before {
  content: '✓';
  font-weight: bold;
}

/* 错误圆圈图标 */
.icon-close-circle::before {
  content: '✕';
  font-weight: bold;
}

/* 图标动画效果 */
.icon-bounce {
  animation: icon-bounce 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes icon-bounce {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.2);
  }
}

.icon-pulse {
  animation: icon-pulse 2s ease-in-out infinite;
}

@keyframes icon-pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.7;
    transform: scale(0.95);
  }
}
